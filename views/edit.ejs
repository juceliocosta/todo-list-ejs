<!DOCTYPE html>
<html>
<head>
  <title>Editar</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <h1>Editar tarefa</h1>

  <form action="/<%= todo.id %>?_method=PUT" method="POST">
    <input 
      type="text" 
      name="task" 
      value="<%= todo.task %>" 
      required 
    />

    <button type="submit">Salvar</button>
  </form>

  <button>
    <a href="/">⬅️ Voltar</a>
  </button>  
</body>
</html>